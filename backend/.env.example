# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/assurances_oued_zem?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# SMTP Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="contact@assurancesoueedzem.ma"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Assurances Oued Zem <noreply@assurancesoueedzem.ma>"

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="assurances-oued-zem"

# Redis
REDIS_URL="redis://localhost:6379"

# SMS (Twilio)
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_FROM="+212XXXXXXXXX"

# Payments
STRIPE_SECRET_KEY="sk_test_..."
CMI_MERCHANT_ID="your-cmi-merchant"
CMI_SECRET="your-cmi-secret"
